# =====================
# Unreal Engine 5
# =====================

# Compiled binaries
Binaries/
Build/
Plugins/*/Binaries/

# Intermediate build files
Intermediate/
Plugins/*/Intermediate/

# Derived data cache (huge, fully regenerated)
DerivedDataCache/

# Saved: logs, screenshots, backups, crashes
Saved/

# =====================
# IDE & Editor files
# =====================

# Visual Studio
*.VC.db
*.VC.VC.opendb
*.opensdf
*.sdf
*.suo
*.user
*.userosscache
*.sln.docstates
.vs/

# Visual Studio Code
.vscode/

# JetBrains Rider
.idea/
*.sln.DotSettings.user

# Solution file (regenerated by UE on project open)
*.sln

# Xcode
*.xcworkspace
*.xcodeproj

# =====================
# OS files
# =====================
.DS_Store
Thumbs.db
Desktop.ini
